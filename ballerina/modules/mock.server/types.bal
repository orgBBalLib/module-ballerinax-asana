    @jsondata:Name {value: "resource_subtype"}
    "default_task"|"milestone"|"approval"|"custom" resourceSubtype?;
    # The user who created this task.
    @jsondata:Name {value: "created_by"}
    TaskCompactCreatedBy createdBy?;
};

